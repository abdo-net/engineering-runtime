{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Reasoning Output Schema",
  "description": "Schema for DERIVED_FACT truth records produced by S5 Reasoning Engines",
  "type": "object",
  "required": ["id", "inference_type", "subject", "statement", "confidence", "evidence", "class", "source_authority"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^derived:[a-zA-Z0-9_.-]+$",
      "description": "Deterministic ID derived from inference_type and subject"
    },
    "inference_type": {
      "type": "string",
      "enum": ["SEMANTIC", "BEHAVIOR", "BUSINESS_RULE", "STATE_MACHINE", "DTO_TRANSFORMATION", "PERMISSION", "ERROR_HANDLING"]
    },
    "subject": {
      "type": "string",
      "description": "Node ID or file path the inference is about"
    },
    "statement": {
      "type": "string",
      "description": "Human-readable inference statement"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Computed from evidence count: 1→0.5, 2→0.7, 3+→0.9"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_ref", "line_range", "quote"],
        "properties": {
          "source_ref": { "type": "string" },
          "line_range": { "type": "string" },
          "quote": { "type": "string" }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of other derived facts this inference depends on"
    },
    "class": {
      "type": "string",
      "const": "DERIVED_FACT"
    },
    "source_authority": {
      "type": "string",
      "const": "REASONING"
    }
  }
}
